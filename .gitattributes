# Default: auto-detect text vs binary; store all text with LF in the repo.
# Working tree gets CRLF on Windows (core.autocrlf=true) or LF elsewhere.
* text=auto eol=lf

# Source files – explicit text + LF in the repo
*.html  text eol=lf
*.htm   text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.svg   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf

# Binary assets – never line-ending convert, never diff as text
*.webp  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.bmp   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp4   binary
*.webm  binary
*.mov   binary
*.mp3   binary
*.wav   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.psd   binary
*.ai    binary
*.fig   binary
